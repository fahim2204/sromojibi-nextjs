Options -MultiViews
DirectorySlash Off

RewriteEngine On

# Keep one canonical URL style: no trailing slash.
RewriteCond %{REQUEST_URI} .+/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Serve Next static-export HTML files for extensionless routes.
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)$ $1.html [L]
